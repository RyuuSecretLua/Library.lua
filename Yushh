local PpyUI={}
PpyUI.__index=PpyUI

local TweenService=game:GetService("TweenService")
local UIS=game:GetService("UserInputService")
local Players=game:GetService("Players")
local LP=Players.LocalPlayer
local PlayerGui=LP:WaitForChild("PlayerGui")

local PURPLE=Color3.fromRGB(110,0,190)
local PURPLE_DIM=Color3.fromRGB(70,0,120)
local BG=Color3.fromRGB(15,15,20)
local CARD=Color3.fromRGB(28,28,36)
local TEXT=Color3.fromRGB(225,225,225)
local SUBTEXT=Color3.fromRGB(160,160,170)
local BAR=Color3.fromRGB(22,22,30)

function PpyUI.new(title)
	local self=setmetatable({},PpyUI)
	self._tabs={}
	self._pages={}
	self._activeTab=nil

	local Gui=Instance.new("ScreenGui")
	Gui.Name="PpyUI_"..title
	Gui.ResetOnSpawn=false
	Gui.IgnoreGuiInset=true
	Gui.Parent=PlayerGui

	local Main=Instance.new("Frame",Gui)
	Main.Size=UDim2.new(0,520,0,340)
	Main.Position=UDim2.new(0.5,-260,0.5,-170)
	Main.BackgroundColor3=BG
	Main.BackgroundTransparency=0.2
	Main.BorderSizePixel=0
	Main.Active=true
	Main.ClipsDescendants=true
	Instance.new("UICorner",Main).CornerRadius=UDim.new(0,12)

	local TopBar=Instance.new("Frame",Main)
	TopBar.Size=UDim2.new(1,0,0,42)
	TopBar.Position=UDim2.new(0,0,0,0)
	TopBar.BackgroundColor3=PURPLE
	TopBar.BackgroundTransparency=0
	TopBar.BorderSizePixel=0
	TopBar.Active=true
	Instance.new("UICorner",TopBar).CornerRadius=UDim.new(0,12)

	local TopFix=Instance.new("Frame",TopBar)
	TopFix.Size=UDim2.new(1,0,0,12)
	TopFix.Position=UDim2.new(0,0,1,-12)
	TopFix.BackgroundColor3=PURPLE
	TopFix.BorderSizePixel=0

	local TitleLabel=Instance.new("TextLabel",TopBar)
	TitleLabel.Size=UDim2.new(1,-44,1,0)
	TitleLabel.Position=UDim2.new(0,0,0,0)
	TitleLabel.Text=title
	TitleLabel.Font=Enum.Font.GothamBold
	TitleLabel.TextSize=16
	TitleLabel.TextColor3=Color3.fromRGB(255,255,255)
	TitleLabel.BackgroundTransparency=1
	TitleLabel.TextXAlignment=Enum.TextXAlignment.Center

	local MinBtn=Instance.new("TextButton",TopBar)
	MinBtn.Size=UDim2.new(0,32,0,32)
	MinBtn.Position=UDim2.new(1,-38,0.5,-16)
	MinBtn.Text="-"
	MinBtn.Font=Enum.Font.GothamBold
	MinBtn.TextSize=22
	MinBtn.TextColor3=Color3.fromRGB(255,255,255)
	MinBtn.BackgroundTransparency=1
	MinBtn.BorderSizePixel=0

	local dragging,dragStart,startPos=false,nil,nil
	TopBar.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			dragging=true
			dragStart=i.Position
			startPos=Main.Position
			i.Changed:Connect(function()
				if i.UserInputState==Enum.UserInputState.End then dragging=false end
			end)
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if dragging and(i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
			local d=i.Position-dragStart
			Main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
		end
	end)

	local TabBar=Instance.new("Frame",Main)
	TabBar.Size=UDim2.new(1,-14,0,32)
	TabBar.Position=UDim2.new(0,7,0,48)
	TabBar.BackgroundColor3=BAR
	TabBar.BackgroundTransparency=0
	TabBar.BorderSizePixel=0
	Instance.new("UICorner",TabBar).CornerRadius=UDim.new(0,8)
	local TBPad=Instance.new("UIPadding",TabBar)
	TBPad.PaddingLeft=UDim.new(0,4)
	TBPad.PaddingRight=UDim.new(0,4)
	TBPad.PaddingTop=UDim.new(0,4)
	TBPad.PaddingBottom=UDim.new(0,4)
	local TBLayout=Instance.new("UIListLayout",TabBar)
	TBLayout.FillDirection=Enum.FillDirection.Horizontal
	TBLayout.Padding=UDim.new(0,4)

	local Pages=Instance.new("Frame",Main)
	Pages.Position=UDim2.new(0,0,0,86)
	Pages.Size=UDim2.new(1,0,1,-92)
	Pages.BackgroundTransparency=1

	self._main=Main
	self._tabBar=TabBar
	self._pages=Pages
	self._minBtn=MinBtn
	self._minimized=false
	self._tabBar=TabBar
	self._pagesFrame=Pages
	self._tabBtns={}
	self._pageFrames={}

	local minimized=false
	MinBtn.MouseButton1Click:Connect(function()
		minimized=not minimized
		if minimized then
			TabBar.Visible=false
			Pages.Visible=false
			TweenService:Create(Main,TweenInfo.new(0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(0,520,0,42)}):Play()
		else
			TweenService:Create(Main,TweenInfo.new(0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.new(0,520,0,340)}):Play()
			task.wait(0.3)
			TabBar.Visible=true
			Pages.Visible=true
		end
	end)

	return self
end

function PpyUI:AddTab(name)
	local page=Instance.new("ScrollingFrame",self._pagesFrame)
	page.Name=name
	page.Size=UDim2.new(1,0,1,0)
	page.BackgroundTransparency=1
	page.Visible=false
	page.ScrollBarThickness=4
	page.ScrollBarImageTransparency=0.4
	page.ScrollingDirection=Enum.ScrollingDirection.Y
	page.Active=true
	local layout=Instance.new("UIListLayout",page)
	layout.Padding=UDim.new(0,6)
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		page.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+14)
	end)
	local pad=Instance.new("UIPadding",page)
	pad.PaddingTop=UDim.new(0,8)
	pad.PaddingLeft=UDim.new(0,10)
	pad.PaddingRight=UDim.new(0,10)

	local btn=Instance.new("TextButton",self._tabBar)
	btn.Size=UDim2.new(0,90,1,0)
	btn.Text=name
	btn.BackgroundColor3=CARD
	btn.BackgroundTransparency=1
	btn.TextColor3=SUBTEXT
	btn.Font=Enum.Font.GothamBold
	btn.TextSize=13
	btn.BorderSizePixel=0
	Instance.new("UICorner",btn).CornerRadius=UDim.new(0,6)

	local tabObj={}
	tabObj._page=page
	tabObj._btn=btn
	tabObj._ui=self

	local function activate()
		for _,v in pairs(self._pagesFrame:GetChildren()) do
			if v:IsA("ScrollingFrame") then v.Visible=false end
		end
		for _,b in pairs(self._tabBar:GetChildren()) do
			if b:IsA("TextButton") then
				b.BackgroundColor3=CARD
				b.BackgroundTransparency=1
				b.TextColor3=SUBTEXT
			end
		end
		page.Visible=true
		btn.BackgroundColor3=PURPLE
		btn.BackgroundTransparency=0
		btn.TextColor3=Color3.fromRGB(255,255,255)
	end

	btn.MouseButton1Click:Connect(activate)

	if #self._pagesFrame:GetChildren()==1 then
		activate()
	end

	function tabObj:CreateSection(text)
		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,24)
		f.BackgroundTransparency=1
		f.BorderSizePixel=0
		local lbl=Instance.new("TextLabel",f)
		lbl.Size=UDim2.new(1,0,1,0)
		lbl.BackgroundTransparency=1
		lbl.Text=text
		lbl.Font=Enum.Font.GothamBold
		lbl.TextSize=12
		lbl.TextColor3=PURPLE
		lbl.TextXAlignment=Enum.TextXAlignment.Center
		return f
	end

	function tabObj:CreateButton(text,callback)
		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,38)
		f.BackgroundColor3=CARD
		f.BackgroundTransparency=0.3
		f.BorderSizePixel=0
		Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)
		local btn2=Instance.new("TextButton",f)
		btn2.Size=UDim2.new(1,0,1,0)
		btn2.BackgroundTransparency=1
		btn2.Text=text
		btn2.Font=Enum.Font.GothamBold
		btn2.TextSize=13
		btn2.TextColor3=TEXT
		btn2.TextXAlignment=Enum.TextXAlignment.Center
		btn2.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)
		return f
	end

	function tabObj:CreateToggle(text,default,callback)
		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,42)
		f.BackgroundColor3=CARD
		f.BackgroundTransparency=0.3
		f.BorderSizePixel=0
		Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)

		local lbl=Instance.new("TextLabel",f)
		lbl.Size=UDim2.new(1,-70,1,0)
		lbl.Position=UDim2.new(0,12,0,0)
		lbl.BackgroundTransparency=1
		lbl.Text=text
		lbl.Font=Enum.Font.GothamBold
		lbl.TextSize=14
		lbl.TextColor3=TEXT
		lbl.TextXAlignment=Enum.TextXAlignment.Left

		local track=Instance.new("TextButton",f)
		track.Size=UDim2.new(0,52,0,26)
		track.Position=UDim2.new(1,-62,0.5,-13)
		track.BackgroundColor3=Color3.fromRGB(50,50,60)
		track.BackgroundTransparency=0
		track.BorderSizePixel=0
		track.Text=""
		Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)

		local circle=Instance.new("Frame",track)
		circle.Size=UDim2.new(0,20,0,20)
		circle.Position=UDim2.new(0,3,0.5,-10)
		circle.BackgroundColor3=Color3.fromRGB(180,180,190)
		circle.BorderSizePixel=0
		Instance.new("UICorner",circle).CornerRadius=UDim.new(1,0)

		local state=default or false
		local function applyState(s)
			if s then
				TweenService:Create(track,TweenInfo.new(0.18),{BackgroundColor3=PURPLE}):Play()
				TweenService:Create(circle,TweenInfo.new(0.18),{Position=UDim2.new(1,-23,0.5,-10),BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
			else
				TweenService:Create(track,TweenInfo.new(0.18),{BackgroundColor3=Color3.fromRGB(50,50,60)}):Play()
				TweenService:Create(circle,TweenInfo.new(0.18),{Position=UDim2.new(0,3,0.5,-10),BackgroundColor3=Color3.fromRGB(180,180,190)}):Play()
			end
			if callback then callback(s) end
		end
		applyState(state)
		track.MouseButton1Click:Connect(function()
			state=not state
			applyState(state)
		end)
		return f
	end

	function tabObj:CreateInput(text,placeholder,callback)
		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,66)
		f.BackgroundColor3=CARD
		f.BackgroundTransparency=0.3
		f.BorderSizePixel=0
		Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)

		local lbl=Instance.new("TextLabel",f)
		lbl.Size=UDim2.new(1,-12,0,24)
		lbl.Position=UDim2.new(0,12,0,4)
		lbl.BackgroundTransparency=1
		lbl.Text=text
		lbl.Font=Enum.Font.GothamBold
		lbl.TextSize=13
		lbl.TextColor3=TEXT
		lbl.TextXAlignment=Enum.TextXAlignment.Left

		local box=Instance.new("TextBox",f)
		box.Size=UDim2.new(1,-20,0,26)
		box.Position=UDim2.new(0,10,0,30)
		box.BackgroundColor3=Color3.fromRGB(20,20,28)
		box.BackgroundTransparency=0
		box.BorderSizePixel=0
		box.PlaceholderText=placeholder or ""
		box.PlaceholderColor3=SUBTEXT
		box.Text=""
		box.Font=Enum.Font.Gotham
		box.TextSize=13
		box.TextColor3=TEXT
		box.ClearTextOnFocus=false
		Instance.new("UICorner",box).CornerRadius=UDim.new(0,6)
		local bpad=Instance.new("UIPadding",box)
		bpad.PaddingLeft=UDim.new(0,8)

		box.FocusLost:Connect(function(enter)
			if enter and callback then callback(box.Text) end
		end)
		return f
	end

	function tabObj:CreateDropdown(text,options,callback)
		local ITEM_H=32
		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,42)
		f.BackgroundColor3=CARD
		f.BackgroundTransparency=0.3
		f.BorderSizePixel=0
		f.ClipsDescendants=false
		Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)

		local lbl=Instance.new("TextLabel",f)
		lbl.Size=UDim2.new(1,-50,1,0)
		lbl.Position=UDim2.new(0,12,0,0)
		lbl.BackgroundTransparency=1
		lbl.Text=text
		lbl.Font=Enum.Font.GothamBold
		lbl.TextSize=13
		lbl.TextColor3=TEXT
		lbl.TextXAlignment=Enum.TextXAlignment.Left

		local selected=Instance.new("TextLabel",f)
		selected.Size=UDim2.new(0,110,1,0)
		selected.Position=UDim2.new(1,-120,0,0)
		selected.BackgroundTransparency=1
		selected.Text=options[1] or ""
		selected.Font=Enum.Font.Gotham
		selected.TextSize=12
		selected.TextColor3=PURPLE
		selected.TextXAlignment=Enum.TextXAlignment.Right

		local arrow=Instance.new("TextLabel",f)
		arrow.Size=UDim2.new(0,20,1,0)
		arrow.Position=UDim2.new(1,-22,0,0)
		arrow.BackgroundTransparency=1
		arrow.Text="▾"
		arrow.Font=Enum.Font.GothamBold
		arrow.TextSize=13
		arrow.TextColor3=SUBTEXT
		arrow.TextXAlignment=Enum.TextXAlignment.Center

		local dropFrame=Instance.new("Frame",f)
		dropFrame.Size=UDim2.new(1,0,0,#options*ITEM_H)
		dropFrame.Position=UDim2.new(0,0,1,4)
		dropFrame.BackgroundColor3=Color3.fromRGB(22,22,30)
		dropFrame.BackgroundTransparency=0
		dropFrame.BorderSizePixel=0
		dropFrame.Visible=false
		dropFrame.ZIndex=10
		Instance.new("UICorner",dropFrame).CornerRadius=UDim.new(0,8)

		for i,opt in ipairs(options) do
			local item=Instance.new("TextButton",dropFrame)
			item.Size=UDim2.new(1,0,0,ITEM_H)
			item.Position=UDim2.new(0,0,0,(i-1)*ITEM_H)
			item.BackgroundTransparency=1
			item.Text=opt
			item.Font=Enum.Font.Gotham
			item.TextSize=13
			item.TextColor3=TEXT
			item.ZIndex=11
			item.MouseButton1Click:Connect(function()
				selected.Text=opt
				dropFrame.Visible=false
				arrow.Text="▾"
				if callback then callback(opt) end
			end)
		end

		local open=false
		local hitbox=Instance.new("TextButton",f)
		hitbox.Size=UDim2.new(1,0,1,0)
		hitbox.BackgroundTransparency=1
		hitbox.Text=""
		hitbox.ZIndex=5
		hitbox.MouseButton1Click:Connect(function()
			open=not open
			dropFrame.Visible=open
			arrow.Text=open and "▴" or "▾"
		end)
		return f
	end

	function tabObj:CreateDropdownMulti(text,options,callback)
		local ITEM_H=32
		local selected={}
		local checks={}

		local f=Instance.new("Frame",page)
		f.Size=UDim2.new(1,0,0,42)
		f.BackgroundColor3=CARD
		f.BackgroundTransparency=0.3
		f.BorderSizePixel=0
		f.ClipsDescendants=false
		Instance.new("UICorner",f).CornerRadius=UDim.new(0,10)

		local lbl=Instance.new("TextLabel",f)
		lbl.Size=UDim2.new(1,-50,1,0)
		lbl.Position=UDim2.new(0,12,0,0)
		lbl.BackgroundTransparency=1
		lbl.Text=text
		lbl.Font=Enum.Font.GothamBold
		lbl.TextSize=13
		lbl.TextColor3=TEXT
		lbl.TextXAlignment=Enum.TextXAlignment.Left

		local countLbl=Instance.new("TextLabel",f)
		countLbl.Size=UDim2.new(0,60,1,0)
		countLbl.Position=UDim2.new(1,-72,0,0)
		countLbl.BackgroundTransparency=1
		countLbl.Text="0 selected"
		countLbl.Font=Enum.Font.Gotham
		countLbl.TextSize=11
		countLbl.TextColor3=PURPLE
		countLbl.TextXAlignment=Enum.TextXAlignment.Right

		local arrow=Instance.new("TextLabel",f)
		arrow.Size=UDim2.new(0,20,1,0)
		arrow.Position=UDim2.new(1,-22,0,0)
		arrow.BackgroundTransparency=1
		arrow.Text="▾"
		arrow.Font=Enum.Font.GothamBold
		arrow.TextSize=13
		arrow.TextColor3=SUBTEXT
		arrow.TextXAlignment=Enum.TextXAlignment.Center

		local dropFrame=Instance.new("Frame",f)
		dropFrame.Size=UDim2.new(1,0,0,#options*ITEM_H)
		dropFrame.Position=UDim2.new(0,0,1,4)
		dropFrame.BackgroundColor3=Color3.fromRGB(22,22,30)
		dropFrame.BackgroundTransparency=0
		dropFrame.BorderSizePixel=0
		dropFrame.Visible=false
		dropFrame.ZIndex=10
		Instance.new("UICorner",dropFrame).CornerRadius=UDim.new(0,8)

		local function updateCount()
			local n=0
			for _ in pairs(selected) do n=n+1 end
			countLbl.Text=n.." selected"
		end

		for i,opt in ipairs(options) do
			local item=Instance.new("Frame",dropFrame)
			item.Size=UDim2.new(1,0,0,ITEM_H)
			item.Position=UDim2.new(0,0,0,(i-1)*ITEM_H)
			item.BackgroundTransparency=1
			item.ZIndex=10

			local checkBg=Instance.new("Frame",item)
			checkBg.Size=UDim2.new(0,18,0,18)
			checkBg.Position=UDim2.new(0,10,0.5,-9)
			checkBg.BackgroundColor3=Color3.fromRGB(40,40,50)
			checkBg.BorderSizePixel=0
			checkBg.ZIndex=11
			Instance.new("UICorner",checkBg).CornerRadius=UDim.new(0,4)

			local checkMark=Instance.new("TextLabel",checkBg)
			checkMark.Size=UDim2.new(1,0,1,0)
			checkMark.BackgroundTransparency=1
			checkMark.Text="✓"
			checkMark.Font=Enum.Font.GothamBold
			checkMark.TextSize=13
			checkMark.TextColor3=Color3.fromRGB(255,255,255)
			checkMark.Visible=false
			checkMark.ZIndex=12

			local itemLbl=Instance.new("TextLabel",item)
			itemLbl.Size=UDim2.new(1,-36,1,0)
			itemLbl.Position=UDim2.new(0,36,0,0)
			itemLbl.BackgroundTransparency=1
			itemLbl.Text=opt
			itemLbl.Font=Enum.Font.Gotham
			itemLbl.TextSize=13
			itemLbl.TextColor3=TEXT
			itemLbl.TextXAlignment=Enum.TextXAlignment.Left
			itemLbl.ZIndex=11

			local btn2=Instance.new("TextButton",item)
			btn2.Size=UDim2.new(1,0,1,0)
			btn2.BackgroundTransparency=1
			btn2.Text=""
			btn2.ZIndex=12
			btn2.MouseButton1Click:Connect(function()
				if selected[opt] then
					selected[opt]=nil
					checkBg.BackgroundColor3=Color3.fromRGB(40,40,50)
					checkMark.Visible=false
				else
					selected[opt]=true
					checkBg.BackgroundColor3=PURPLE
					checkMark.Visible=true
				end
				updateCount()
				local result={}
				for k in pairs(selected) do table.insert(result,k) end
				if callback then callback(result) end
			end)
		end

		local open=false
		local hitbox=Instance.new("TextButton",f)
		hitbox.Size=UDim2.new(1,0,1,0)
		hitbox.BackgroundTransparency=1
		hitbox.Text=""
		hitbox.ZIndex=5
		hitbox.MouseButton1Click:Connect(function()
			open=not open
			dropFrame.Visible=open
			arrow.Text=open and "▴" or "▾"
		end)
		return f
	end

	return tabObj
end

return PpyUI
