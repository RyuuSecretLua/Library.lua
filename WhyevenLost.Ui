local WhylostEven={}
WhylostEven.__index=WhylostEven

local Players=game:GetService("Players")
local LP=Players.LocalPlayer
local PlayerGui=LP:WaitForChild("PlayerGui")
local UIS=game:GetService("UserInputService")

function WhylostEven.new(config)
	local self=setmetatable({},WhylostEven)
	config=config or {}

	local Gui=Instance.new("ScreenGui")
	Gui.Name="WhylostEvenUI"
	Gui.ResetOnSpawn=false
	Gui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
	Gui.Parent=PlayerGui

	local Main=Instance.new("Frame",Gui)
	Main.Size=UDim2.new(0,520,0,45)
	Main.Position=UDim2.new(0.5,-260,0.5,-150)
	Main.BackgroundColor3=Color3.fromRGB(15,15,15)
	Main.BorderSizePixel=0
	Main.Active=true
	Main.ClipsDescendants=true
	Instance.new("UICorner",Main).CornerRadius=UDim.new(0,6)

	local MainStroke=Instance.new("UIStroke",Main)
	MainStroke.Color=config.BorderColor or Color3.fromRGB(255,30,30)
	MainStroke.Thickness=3
	MainStroke.Transparency=0
	MainStroke.ApplyStrokeMode=Enum.ApplyStrokeMode.Border

	local BG=Instance.new("ImageLabel",Main)
	BG.Size=UDim2.new(1,0,1,0)
	BG.Position=UDim2.new(0,0,0,0)
	BG.Image=config.Image or ""
	BG.BackgroundTransparency=1
	BG.ImageTransparency=0.4
	BG.ScaleType=Enum.ScaleType.Crop
	BG.ZIndex=1

	local Overlay=Instance.new("Frame",Main)
	Overlay.Size=UDim2.new(1,0,1,0)
	Overlay.BackgroundColor3=Color3.fromRGB(10,10,10)
	Overlay.BackgroundTransparency=0.5
	Overlay.BorderSizePixel=0
	Overlay.ZIndex=2

	local Top=Instance.new("Frame",Main)
	Top.Size=UDim2.new(1,0,0,45)
	Top.BackgroundColor3=Color3.fromRGB(20,20,20)
	Top.BackgroundTransparency=0.2
	Top.BorderSizePixel=0
	Top.Active=true
	Top.ZIndex=3
	Instance.new("UICorner",Top).CornerRadius=UDim.new(0,6)

	local dragging=false
	local dragStart
	local startPos

	Top.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			dragging=true
			dragStart=i.Position
			startPos=Main.Position
			i.Changed:Connect(function()
				if i.UserInputState==Enum.UserInputState.End then
					dragging=false
				end
			end)
		end
	end)

	UIS.InputChanged:Connect(function(i)
		if dragging and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
			local delta=i.Position-dragStart
			Main.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+delta.X,startPos.Y.Scale,startPos.Y.Offset+delta.Y)
		end
	end)

	local Title=Instance.new("TextLabel",Top)
	Title.Size=UDim2.new(1,0,1,0)
	Title.Position=UDim2.new(0,0,0,0)
	Title.Text=config.Title or "WhylostEven UI"
	Title.Font=Enum.Font.Code
	Title.TextSize=18
	Title.TextColor3=Color3.fromRGB(255,255,255)
	Title.BackgroundTransparency=1
	Title.TextXAlignment=Enum.TextXAlignment.Center
	Title.ZIndex=4

	local Minimize=Instance.new("TextButton",Top)
	Minimize.Size=UDim2.new(0,30,0,30)
	Minimize.Position=UDim2.new(1,-70,0.5,-15)
	Minimize.Text="-"
	Minimize.Font=Enum.Font.Code
	Minimize.TextSize=18
	Minimize.TextColor3=Color3.new(1,1,1)
	Minimize.BackgroundColor3=Color3.fromRGB(40,40,40)
	Minimize.BorderSizePixel=0
	Minimize.ZIndex=4
	Instance.new("UICorner",Minimize).CornerRadius=UDim.new(1,0)

	local Close=Instance.new("TextButton",Top)
	Close.Size=UDim2.new(0,30,0,30)
	Close.Position=UDim2.new(1,-35,0.5,-15)
	Close.Text="X"
	Close.Font=Enum.Font.Code
	Close.TextSize=14
	Close.TextColor3=Color3.new(1,1,1)
	Close.BackgroundColor3=Color3.fromRGB(120,30,30)
	Close.BorderSizePixel=0
	Close.ZIndex=4
	Instance.new("UICorner",Close).CornerRadius=UDim.new(1,0)

	local TabBar=Instance.new("Frame",Main)
	TabBar.Size=UDim2.new(1,0,0,36)
	TabBar.Position=UDim2.new(0,0,0,45)
	TabBar.BackgroundTransparency=1
	TabBar.BorderSizePixel=0
	TabBar.ZIndex=3

	local TabBarLayout=Instance.new("UIListLayout",TabBar)
	TabBarLayout.FillDirection=Enum.FillDirection.Horizontal
	TabBarLayout.Padding=UDim.new(0,6)

	local TabBarPad=Instance.new("UIPadding",TabBar)
	TabBarPad.PaddingLeft=UDim.new(0,8)
	TabBarPad.PaddingTop=UDim.new(0,6)

	self._main=Main
	self._tabBar=TabBar
	self._tabs={}
	self._gui=Gui
	self._accentColor=config.AccentColor or Color3.fromRGB(255,30,30)
	self._MAX_HEIGHT=300
	self._isMinimized=false
	self._currentTab=nil

	local function refreshSize()
		if self._currentTab and not self._isMinimized then
			local h=self._currentTab.Layout.AbsoluteContentSize.Y
			local clampedH=math.min(h,self._MAX_HEIGHT)
			self._currentTab.Content.Size=UDim2.new(1,-16,0,clampedH+15)
			self._currentTab.Content.CanvasSize=UDim2.new(0,0,0,h+20)
			Main.Size=UDim2.new(0,520,0,clampedH+105)
		end
	end

	self._refreshSize=refreshSize

	Minimize.MouseButton1Click:Connect(function()
		self._isMinimized=not self._isMinimized
		TabBar.Visible=not self._isMinimized
		if self._currentTab then
			self._currentTab.Content.Visible=not self._isMinimized
		end
		if self._isMinimized then
			Main.Size=UDim2.new(0,520,0,45)
		else
			refreshSize()
		end
	end)

	Close.MouseButton1Click:Connect(function()
		Gui:Destroy()
	end)

	return self
end

function WhylostEven:NewTab(name)
	local tabBtn=Instance.new("TextButton",self._tabBar)
	tabBtn.Size=UDim2.new(0,80,0,26)
	tabBtn.BackgroundColor3=Color3.fromRGB(35,35,35)
	tabBtn.BackgroundTransparency=0.6
	tabBtn.BorderSizePixel=0
	tabBtn.Text=name
	tabBtn.Font=Enum.Font.Code
	tabBtn.TextSize=13
	tabBtn.TextColor3=Color3.fromRGB(200,200,200)
	tabBtn.ZIndex=4
	Instance.new("UICorner",tabBtn).CornerRadius=UDim.new(0,8)

	local tabContent=Instance.new("ScrollingFrame",self._main)
	tabContent.Position=UDim2.new(0,8,0,88)
	tabContent.Size=UDim2.new(1,-16,0,100)
	tabContent.BackgroundTransparency=1
	tabContent.BorderSizePixel=0
	tabContent.ScrollBarThickness=4
	tabContent.ScrollBarImageColor3=self._accentColor
	tabContent.ScrollBarImageTransparency=0.5
	tabContent.ScrollingDirection=Enum.ScrollingDirection.Y
	tabContent.Active=true
	tabContent.Selectable=true
	tabContent.ZIndex=3
	tabContent.Visible=false

	local tabLayout=Instance.new("UIListLayout",tabContent)
	tabLayout.Padding=UDim.new(0,6)

	local tabPad=Instance.new("UIPadding",tabContent)
	tabPad.PaddingTop=UDim.new(0,6)
	tabPad.PaddingBottom=UDim.new(0,6)
	tabPad.PaddingLeft=UDim.new(0,2)
	tabPad.PaddingRight=UDim.new(0,2)

	local tab={
		Content=tabContent,
		Layout=tabLayout,
		Button=tabBtn,
		Name=name
	}

	table.insert(self._tabs,tab)

	local selfRef=self

	local function selectTab()
		for _,t in pairs(selfRef._tabs) do
			t.Content.Visible=false
			t.Button.TextColor3=Color3.fromRGB(200,200,200)
			t.Button.BackgroundTransparency=0.6
		end
		tabContent.Visible=true
		tabBtn.TextColor3=Color3.fromRGB(255,255,255)
		tabBtn.BackgroundTransparency=0.1
		selfRef._currentTab=tab

		tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			if selfRef._currentTab==tab and not selfRef._isMinimized then
				selfRef._refreshSize()
			end
		end)
		selfRef._refreshSize()
	end

	tabBtn.MouseButton1Click:Connect(selectTab)

	if #self._tabs==1 then
		selectTab()
	end

	local accent=self._accentColor
	local main=self._main

	local tabObj={}
	tabObj._content=tabContent
	tabObj._accent=accent
	tabObj._main=main

	function tabObj:AddToggle(text,callback)
		local Frame=Instance.new("Frame",self._content)
		Frame.Size=UDim2.new(1,-4,0,36)
		Frame.BackgroundColor3=Color3.fromRGB(35,35,35)
		Frame.BackgroundTransparency=0.3
		Frame.BorderSizePixel=0
		Frame.ZIndex=4
		Instance.new("UICorner",Frame).CornerRadius=UDim.new(0,8)

		local Txt=Instance.new("TextLabel",Frame)
		Txt.Size=UDim2.new(1,-70,1,0)
		Txt.Position=UDim2.new(0,12,0,0)
		Txt.Text=text
		Txt.Font=Enum.Font.Code
		Txt.TextSize=14
		Txt.TextColor3=Color3.fromRGB(220,220,220)
		Txt.BackgroundTransparency=1
		Txt.TextXAlignment=Enum.TextXAlignment.Left
		Txt.ZIndex=5

		local Btn=Instance.new("TextButton",Frame)
		Btn.Size=UDim2.new(0,42,0,22)
		Btn.Position=UDim2.new(1,-54,0.5,-11)
		Btn.BackgroundColor3=Color3.fromRGB(60,60,60)
		Btn.BorderSizePixel=0
		Btn.Text=""
		Btn.ZIndex=5
		Instance.new("UICorner",Btn).CornerRadius=UDim.new(1,0)

		local Circle=Instance.new("Frame",Btn)
		Circle.Size=UDim2.new(0,18,0,18)
		Circle.Position=UDim2.new(0,2,0.5,-9)
		Circle.BackgroundColor3=Color3.fromRGB(200,200,200)
		Circle.BorderSizePixel=0
		Circle.ZIndex=6
		Instance.new("UICorner",Circle).CornerRadius=UDim.new(1,0)

		local state=false
		Btn.MouseButton1Click:Connect(function()
			state=not state
			if state then
				Btn.BackgroundColor3=self._accent
				Circle.BackgroundColor3=Color3.fromRGB(255,255,255)
				Circle.Position=UDim2.new(1,-20,0.5,-9)
			else
				Btn.BackgroundColor3=Color3.fromRGB(60,60,60)
				Circle.BackgroundColor3=Color3.fromRGB(200,200,200)
				Circle.Position=UDim2.new(0,2,0.5,-9)
			end
			if callback then callback(state) end
		end)
	end

	function tabObj:AddButton(text,callback)
		local Frame=Instance.new("Frame",self._content)
		Frame.Size=UDim2.new(1,-4,0,36)
		Frame.BackgroundColor3=Color3.fromRGB(35,35,35)
		Frame.BackgroundTransparency=0.3
		Frame.BorderSizePixel=0
		Frame.ZIndex=4
		Instance.new("UICorner",Frame).CornerRadius=UDim.new(0,8)

		local Txt=Instance.new("TextLabel",Frame)
		Txt.Size=UDim2.new(1,0,1,0)
		Txt.Text=text
		Txt.Font=Enum.Font.Code
		Txt.TextSize=14
		Txt.TextColor3=Color3.fromRGB(220,220,220)
		Txt.BackgroundTransparency=1
		Txt.TextXAlignment=Enum.TextXAlignment.Center
		Txt.ZIndex=5

		local Btn=Instance.new("TextButton",Frame)
		Btn.Size=UDim2.new(1,0,1,0)
		Btn.BackgroundTransparency=1
		Btn.Text=""
		Btn.ZIndex=5
		Btn.MouseButton1Click:Connect(function()
			if callback then callback() end
		end)
	end

	function tabObj:AddInput(text,placeholder,callback)
		local Frame=Instance.new("Frame",self._content)
		Frame.Size=UDim2.new(1,-4,0,58)
		Frame.BackgroundColor3=Color3.fromRGB(35,35,35)
		Frame.BackgroundTransparency=0.3
		Frame.BorderSizePixel=0
		Frame.ZIndex=4
		Instance.new("UICorner",Frame).CornerRadius=UDim.new(0,8)

		local Lbl=Instance.new("TextLabel",Frame)
		Lbl.Size=UDim2.new(1,-10,0,22)
		Lbl.Position=UDim2.new(0,12,0,5)
		Lbl.Text=text
		Lbl.Font=Enum.Font.Code
		Lbl.TextSize=13
		Lbl.TextColor3=Color3.fromRGB(180,180,180)
		Lbl.BackgroundTransparency=1
		Lbl.TextXAlignment=Enum.TextXAlignment.Left
		Lbl.ZIndex=5

		local Box=Instance.new("TextBox",Frame)
		Box.Size=UDim2.new(1,-20,0,24)
		Box.Position=UDim2.new(0,10,0,28)
		Box.BackgroundColor3=Color3.fromRGB(25,25,25)
		Box.BackgroundTransparency=0.2
		Box.BorderSizePixel=0
		Box.Font=Enum.Font.Code
		Box.TextSize=13
		Box.TextColor3=Color3.fromRGB(220,220,220)
		Box.PlaceholderText=placeholder or ""
		Box.PlaceholderColor3=Color3.fromRGB(100,100,100)
		Box.Text=""
		Box.ZIndex=5
		Box.ClearTextOnFocus=false
		Instance.new("UICorner",Box).CornerRadius=UDim.new(0,6)

		Box.FocusLost:Connect(function(enter)
			if enter and callback then
				callback(Box.Text)
			end
		end)
	end

	function tabObj:AddSelect(text,options,callback)
		local isOpen=false

		local Wrapper=Instance.new("Frame",self._content)
		Wrapper.Size=UDim2.new(1,-4,0,36)
		Wrapper.BackgroundTransparency=1
		Wrapper.BorderSizePixel=0
		Wrapper.ZIndex=4
		Wrapper.ClipsDescendants=false

		local Header=Instance.new("Frame",Wrapper)
		Header.Size=UDim2.new(1,0,0,36)
		Header.BackgroundColor3=Color3.fromRGB(35,35,35)
		Header.BackgroundTransparency=0.3
		Header.BorderSizePixel=0
		Header.ZIndex=4
		Instance.new("UICorner",Header).CornerRadius=UDim.new(0,8)

		local Lbl=Instance.new("TextLabel",Header)
		Lbl.Size=UDim2.new(0.5,0,1,0)
		Lbl.Position=UDim2.new(0,12,0,0)
		Lbl.Text=text
		Lbl.Font=Enum.Font.Code
		Lbl.TextSize=14
		Lbl.TextColor3=Color3.fromRGB(220,220,220)
		Lbl.BackgroundTransparency=1
		Lbl.TextXAlignment=Enum.TextXAlignment.Left
		Lbl.ZIndex=5

		local Selected=Instance.new("TextLabel",Header)
		Selected.Size=UDim2.new(0.3,0,1,0)
		Selected.Position=UDim2.new(0.5,0,0,0)
		Selected.Text=options[1] or ""
		Selected.Font=Enum.Font.Code
		Selected.TextSize=13
		Selected.TextColor3=self._accent
		Selected.BackgroundTransparency=1
		Selected.TextXAlignment=Enum.TextXAlignment.Right
		Selected.ZIndex=5

		local Arrow=Instance.new("TextLabel",Header)
		Arrow.Size=UDim2.new(0,30,1,0)
		Arrow.Position=UDim2.new(1,-32,0,0)
		Arrow.Text="v"
		Arrow.Font=Enum.Font.Code
		Arrow.TextSize=14
		Arrow.TextColor3=Color3.fromRGB(200,200,200)
		Arrow.BackgroundTransparency=1
		Arrow.TextXAlignment=Enum.TextXAlignment.Center
		Arrow.ZIndex=5

		local optionHeight=#options*32+8

		local Dropdown=Instance.new("Frame",Wrapper)
		Dropdown.Position=UDim2.new(0,0,0,40)
		Dropdown.Size=UDim2.new(1,0,0,optionHeight)
		Dropdown.BackgroundColor3=Color3.fromRGB(25,25,25)
		Dropdown.BackgroundTransparency=0.1
		Dropdown.BorderSizePixel=0
		Dropdown.ZIndex=20
		Dropdown.Visible=false
		Instance.new("UICorner",Dropdown).CornerRadius=UDim.new(0,8)

		local DLayout=Instance.new("UIListLayout",Dropdown)
		DLayout.Padding=UDim.new(0,2)

		local DPad=Instance.new("UIPadding",Dropdown)
		DPad.PaddingTop=UDim.new(0,4)
		DPad.PaddingBottom=UDim.new(0,4)
		DPad.PaddingLeft=UDim.new(0,6)
		DPad.PaddingRight=UDim.new(0,6)

		for i,opt in ipairs(options) do
			local OBtn=Instance.new("TextButton",Dropdown)
			OBtn.Size=UDim2.new(1,0,0,28)
			OBtn.BackgroundColor3=Color3.fromRGB(40,40,40)
			OBtn.BackgroundTransparency=0.4
			OBtn.BorderSizePixel=0
			OBtn.Text=opt
			OBtn.Font=Enum.Font.Code
			OBtn.TextSize=13
			OBtn.TextColor3=Color3.fromRGB(220,220,220)
			OBtn.TextXAlignment=Enum.TextXAlignment.Left
			OBtn.ZIndex=21
			Instance.new("UICorner",OBtn).CornerRadius=UDim.new(0,6)

			local OPad=Instance.new("UIPadding",OBtn)
			OPad.PaddingLeft=UDim.new(0,10)

			OBtn.MouseButton1Click:Connect(function()
				Selected.Text=opt
				isOpen=false
				Dropdown.Visible=false
				Arrow.Text="v"
				Wrapper.Size=UDim2.new(1,-4,0,36)
				if callback then callback(opt) end
			end)
		end

		local HeaderBtn=Instance.new("TextButton",Header)
		HeaderBtn.Size=UDim2.new(1,0,1,0)
		HeaderBtn.BackgroundTransparency=1
		HeaderBtn.Text=""
		HeaderBtn.ZIndex=6
		HeaderBtn.MouseButton1Click:Connect(function()
			isOpen=not isOpen
			Dropdown.Visible=isOpen
			Arrow.Text=isOpen and "^" or "v"
			Wrapper.Size=UDim2.new(1,-4,0,isOpen and 36+optionHeight+4 or 36)
		end)
	end

	function tabObj:AddSelectToggle(text,options,callback)
		local isOpen=false
		local selected={}

		local Wrapper=Instance.new("Frame",self._content)
		Wrapper.Size=UDim2.new(1,-4,0,36)
		Wrapper.BackgroundTransparency=1
		Wrapper.BorderSizePixel=0
		Wrapper.ZIndex=4
		Wrapper.ClipsDescendants=false

		local Header=Instance.new("Frame",Wrapper)
		Header.Size=UDim2.new(1,0,0,36)
		Header.BackgroundColor3=Color3.fromRGB(35,35,35)
		Header.BackgroundTransparency=0.3
		Header.BorderSizePixel=0
		Header.ZIndex=4
		Instance.new("UICorner",Header).CornerRadius=UDim.new(0,8)

		local Lbl=Instance.new("TextLabel",Header)
		Lbl.Size=UDim2.new(0.8,0,1,0)
		Lbl.Position=UDim2.new(0,12,0,0)
		Lbl.Text=text
		Lbl.Font=Enum.Font.Code
		Lbl.TextSize=14
		Lbl.TextColor3=Color3.fromRGB(220,220,220)
		Lbl.BackgroundTransparency=1
		Lbl.TextXAlignment=Enum.TextXAlignment.Left
		Lbl.ZIndex=5

		local Arrow=Instance.new("TextLabel",Header)
		Arrow.Size=UDim2.new(0,30,1,0)
		Arrow.Position=UDim2.new(1,-32,0,0)
		Arrow.Text="v"
		Arrow.Font=Enum.Font.Code
		Arrow.TextSize=14
		Arrow.TextColor3=Color3.fromRGB(200,200,200)
		Arrow.BackgroundTransparency=1
		Arrow.TextXAlignment=Enum.TextXAlignment.Center
		Arrow.ZIndex=5

		local optionHeight=#options*34+8

		local Dropdown=Instance.new("Frame",Wrapper)
		Dropdown.Position=UDim2.new(0,0,0,40)
		Dropdown.Size=UDim2.new(1,0,0,optionHeight)
		Dropdown.BackgroundColor3=Color3.fromRGB(25,25,25)
		Dropdown.BackgroundTransparency=0.1
		Dropdown.BorderSizePixel=0
		Dropdown.ZIndex=20
		Dropdown.Visible=false
		Instance.new("UICorner",Dropdown).CornerRadius=UDim.new(0,8)

		local DLayout=Instance.new("UIListLayout",Dropdown)
		DLayout.Padding=UDim.new(0,2)

		local DPad=Instance.new("UIPadding",Dropdown)
		DPad.PaddingTop=UDim.new(0,4)
		DPad.PaddingBottom=UDim.new(0,4)
		DPad.PaddingLeft=UDim.new(0,6)
		DPad.PaddingRight=UDim.new(0,6)

		for _,opt in ipairs(options) do
			local Row=Instance.new("Frame",Dropdown)
			Row.Size=UDim2.new(1,0,0,30)
			Row.BackgroundColor3=Color3.fromRGB(40,40,40)
			Row.BackgroundTransparency=0.4
			Row.BorderSizePixel=0
			Row.ZIndex=21
			Instance.new("UICorner",Row).CornerRadius=UDim.new(0,6)

			local Check=Instance.new("Frame",Row)
			Check.Size=UDim2.new(0,18,0,18)
			Check.Position=UDim2.new(0,8,0.5,-9)
			Check.BackgroundColor3=Color3.fromRGB(50,50,50)
			Check.BorderSizePixel=0
			Check.ZIndex=22
			Instance.new("UICorner",Check).CornerRadius=UDim.new(0,4)

			local CheckMark=Instance.new("TextLabel",Check)
			CheckMark.Size=UDim2.new(1,0,1,0)
			CheckMark.Text="✓"
			CheckMark.Font=Enum.Font.Code
			CheckMark.TextSize=14
			CheckMark.TextColor3=Color3.fromRGB(255,255,255)
			CheckMark.BackgroundTransparency=1
			CheckMark.Visible=false
			CheckMark.ZIndex=23

			local OptLbl=Instance.new("TextLabel",Row)
			OptLbl.Size=UDim2.new(1,-36,1,0)
			OptLbl.Position=UDim2.new(0,34,0,0)
			OptLbl.Text=opt
			OptLbl.Font=Enum.Font.Code
			OptLbl.TextSize=13
			OptLbl.TextColor3=Color3.fromRGB(220,220,220)
			OptLbl.BackgroundTransparency=1
			OptLbl.TextXAlignment=Enum.TextXAlignment.Left
			OptLbl.ZIndex=22

			local RowBtn=Instance.new("TextButton",Row)
			RowBtn.Size=UDim2.new(1,0,1,0)
			RowBtn.BackgroundTransparency=1
			RowBtn.Text=""
			RowBtn.ZIndex=23

			local state=false
			RowBtn.MouseButton1Click:Connect(function()
				state=not state
				CheckMark.Visible=state
				Check.BackgroundColor3=state and self._accent or Color3.fromRGB(50,50,50)
				selected[opt]=state
				if callback then callback(opt,state,selected) end
			end)
		end

		local HeaderBtn=Instance.new("TextButton",Header)
		HeaderBtn.Size=UDim2.new(1,0,1,0)
		HeaderBtn.BackgroundTransparency=1
		HeaderBtn.Text=""
		HeaderBtn.ZIndex=6
		HeaderBtn.MouseButton1Click:Connect(function()
			isOpen=not isOpen
			Dropdown.Visible=isOpen
			Arrow.Text=isOpen and "^" or "v"
			Wrapper.Size=UDim2.new(1,-4,0,isOpen and 36+optionHeight+4 or 36)
		end)
	end

	return tabObj
end

return WhylostEven
